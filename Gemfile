source "https://rubygems.org"

# 本地预览：独立 Jekyll 环境，支持 jekyll-paginate-v2
gem "jekyll", "~> 3.9"
gem "minima", "~> 2.5"

gem "kramdown-parser-gfm"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-paginate-v2", "~> 3.0"
end

# Ruby 3+ 本地运行可能需要
gem "webrick", "~> 1.8"

